{
  "name": "mdviewer",
  "version": "2.0.0",
  "description": "A lightweight Markdown & JSON viewer for Windows",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "author": "MDViewer",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "highlight.js": "^11.9.0",
    "markdown-it": "^14.0.0",
    "markdown-it-task-lists": "^2.1.1",
    "mermaid": "^11.13.0"
  },
  "build": {
    "appId": "com.mdviewer.app",
    "productName": "MDViewer",
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.png",
      "fileAssociations": [
        {
          "ext": "md",
          "name": "Markdown File",
          "description": "Markdown Document",
          "role": "Viewer",
          "icon": "assets/icon.png"
        },
        {
          "ext": "markdown",
          "name": "Markdown File",
          "description": "Markdown Document",
          "role": "Viewer",
          "icon": "assets/icon.png"
        },
        {
          "ext": "json",
          "name": "JSON File",
          "description": "JSON Document",
          "role": "Viewer",
          "icon": "assets/icon.png"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "MDViewer"
    },
    "files": [
      "main.js",
      "index.html",
      "renderer.js",
      "preload.js",
      "styles.css",
      "assets/**/*",
      "node_modules/**/*"
    ]
  }
}
